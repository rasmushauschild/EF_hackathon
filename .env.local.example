# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and auto-copied into each Conductor workspace
# (see .worktreeinclude).

# Required: Anthropic API key for query planning + relevance ranking.
ANTHROPIC_API_KEY=

# Required for the YouTube source (MVP). Google Cloud > APIs & Services >
# Credentials > API key, with "YouTube Data API v3" enabled.
YOUTUBE_API_KEY=

# Optional model overrides (sensible defaults are used if unset).
# PLAN_MODEL=claude-sonnet-4-6
# RANK_MODEL=claude-sonnet-4-6

# --- Added in later phases ---

# X / Twitter (pay-per-use). App-only OAuth2 Bearer token.
X_BEARER_TOKEN=

# Reddit (optional; public *.json search works without these at low volume).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
